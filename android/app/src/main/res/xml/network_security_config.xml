<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Allow cleartext (HTTP) traffic globally.
      Many Emby servers run on HTTP (port 8096) on local networks.
      The app warns users about HTTP in the UI instead of blocking it.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
